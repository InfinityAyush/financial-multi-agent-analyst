FROM python:3.12-slim

ENV PYTHONUNBUFFERED=1
ENV UV_HTTP_TIMEOUT=300
ENV VOYAGE_API_KEY=""

WORKDIR /app

# System deps (separate layer — rarely changes)
RUN apt-get update && apt-get install -y \
    build-essential \
    gcc \
    curl \
    && rm -rf /var/lib/apt/lists/*

RUN pip install uv

# Copy dependency files BEFORE source code
# This way Docker reuses the installed packages layer on code-only changes
COPY pyproject.toml uv.lock ./

# Install all project dependencies
RUN uv sync --no-dev

# Now copy source code (changes frequently — last layer)
COPY backend/ ./backend/
COPY data/ ./data/



EXPOSE 8000

# Health check endpoint — used by docker-compose and Render
HEALTHCHECK --interval=30s --timeout=10s --start-period=40s --retries=3 \
    CMD curl -f http://localhost:8000/health || exit 1

CMD ["uv", "run", "uvicorn", "backend.main:app", "--host", "0.0.0.0", "--port", "8000"]